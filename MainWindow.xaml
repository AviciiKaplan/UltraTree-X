<Window x:Class="UltraTree.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        xmlns:local="clr-namespace:UltraTree"
        Title="UltraTree" Height="900" Width="1400" WindowStartupLocation="CenterScreen" Background="#0F1115">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <SolidColorBrush x:Key="AppBackground" Color="#0F1115"/>
        <SolidColorBrush x:Key="PanelBackground" Color="#1A1D24"/>
        <SolidColorBrush x:Key="CardBackground" Color="#222733"/>
        <SolidColorBrush x:Key="SurfaceBackground" Color="#1C2128"/>
        <SolidColorBrush x:Key="BorderColor" Color="#2E3440"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#AAB2BF"/>
        <SolidColorBrush x:Key="AccentBlue" Color="#3B82F6"/>
        <SolidColorBrush x:Key="RowHover" Color="#2A3140"/>
        <SolidColorBrush x:Key="RowSelected" Color="#334155"/>

        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#334155"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#2A3140"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FFFFFF"/>

        <ContextMenu x:Key="RowContextMenu" Background="{StaticResource CardBackground}" BorderBrush="{StaticResource BorderColor}" Foreground="{StaticResource TextPrimary}">
            <MenuItem Header="Open" Command="{Binding DataContext.OpenPathCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding Path}">
                <MenuItem.Icon>
                    <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource AccentBlue}"/>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="Copy Path" Command="{Binding DataContext.CopyPathCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding Path}"/>
        </ContextMenu>

        <Style x:Key="ProProgress" TargetType="ProgressBar">
            <Setter Property="Background" Value="#0A0A0C"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBlue}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Border Background="{TemplateBinding Background}" CornerRadius="2"/>
                            <Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}" CornerRadius="2" HorizontalAlignment="Left"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <HierarchicalDataTemplate DataType="{x:Type local:TreeNode}" ItemsSource="{Binding Children}">
            <Grid Margin="0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition SharedSizeGroup="ColName" Width="Auto"/>
                    <ColumnDefinition SharedSizeGroup="ColPercent" Width="140"/>
                    <ColumnDefinition SharedSizeGroup="ColSize" Width="110"/>
                    <ColumnDefinition SharedSizeGroup="ColAlloc" Width="110"/>
                    <ColumnDefinition SharedSizeGroup="ColItems" Width="90"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Grid.Column="0" MinWidth="420">
                    <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,12,0" 
                               VerticalAlignment="Center" Foreground="{StaticResource AccentBlue}" Opacity="0.8" 
                               Visibility="{Binding IsDirectory, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontSize="13" 
                               Foreground="{StaticResource TextPrimary}" FontWeight="Medium"/>
                </StackPanel>

                <Grid Grid.Column="1" Margin="25,0">
                    <ProgressBar Value="{Binding PercentOfParent, Mode=OneWay}" Maximum="100" Height="6" Style="{StaticResource ProProgress}"/>
                </Grid>

                <TextBlock Grid.Column="2" Text="{Binding SizeHuman}" TextAlignment="Right" Foreground="{StaticResource TextSecondary}" FontFamily="Consolas" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="3" Text="{Binding AllocatedHuman}" TextAlignment="Right" Foreground="{StaticResource TextSecondary}" FontFamily="Consolas" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="4" Text="{Binding ItemCountText}" TextAlignment="Right" Foreground="{StaticResource TextSecondary}" FontFamily="Consolas" VerticalAlignment="Center"/>
            </Grid>
        </HierarchicalDataTemplate>

        <Style TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
            <Setter Property="ContextMenu" Value="{StaticResource RowContextMenu}"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource RowHover}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource RowSelected}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
        </Style>
        
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="ContextMenu" Value="{StaticResource RowContextMenu}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource RowHover}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource RowSelected}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
        </Style>
    </Window.Resources>

    <DockPanel Background="{StaticResource AppBackground}">
        <Border DockPanel.Dock="Top" Background="{StaticResource PanelBackground}" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1" Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding TotalSpaceText}" Foreground="{StaticResource TextPrimary}" FontSize="24" FontWeight="Bold"/>
                    <TextBlock Text="{Binding SpaceUsedText}" Foreground="{StaticResource TextSecondary}" FontSize="14"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="UltraTree" FontSize="26" FontWeight="Bold" Foreground="{StaticResource AccentBlue}" Margin="0,0,30,0" VerticalAlignment="Center"/>
                    <ComboBox Width="160" Height="34" ItemsSource="{Binding Drives}" SelectedItem="{Binding SelectedDrive}" Margin="0,0,12,0" VerticalContentAlignment="Center"/>
                    <Button Content="Scan Drive" Command="{Binding ScanCommand}" Width="110" Height="34" Background="{StaticResource AccentBlue}" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Margin="16" Background="Transparent" BorderThickness="0">
            <TabItem Header="Tree Analysis">
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="420"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="{StaticResource PanelBackground}" CornerRadius="12" Padding="20" BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                        <DockPanel>
                            <Grid DockPanel.Dock="Top" Grid.IsSharedSizeScope="True" Margin="28,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition SharedSizeGroup="ColName" Width="Auto"/>
                                    <ColumnDefinition SharedSizeGroup="ColPercent" Width="140"/>
                                    <ColumnDefinition SharedSizeGroup="ColSize" Width="110"/>
                                    <ColumnDefinition SharedSizeGroup="ColAlloc" Width="110"/>
                                    <ColumnDefinition SharedSizeGroup="ColItems" Width="90"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="NAME" Foreground="{StaticResource TextSecondary}" FontSize="11" FontWeight="Bold" MinWidth="420"/>
                                <TextBlock Grid.Column="1" Text="USAGE" Foreground="{StaticResource TextSecondary}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="SIZE" Foreground="{StaticResource TextSecondary}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Right"/>
                                <TextBlock Grid.Column="3" Text="ALLOCATED" Foreground="{StaticResource TextSecondary}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Right"/>
                                <TextBlock Grid.Column="4" Text="ITEMS" Foreground="{StaticResource TextSecondary}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Right"/>
                            </Grid>

                            <TreeView x:Name="TreeNavGrid" ItemsSource="{Binding DriveTree}" Background="Transparent" BorderThickness="0"/>
                        </DockPanel>
                    </Border>

                    <Border Grid.Column="1" Margin="16,0,0,0" Background="{StaticResource CardBackground}" CornerRadius="12" Padding="24" BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Storage Distribution" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center" Margin="0,0,0,30"/>
                            <lvc:PieChart Grid.Row="1" Series="{Binding FolderPieSeries}" LegendPosition="Bottom" LegendTextPaint="{Binding LegendTextPaint}" Background="Transparent" />
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Top Files">
                <Border Margin="0,12,0,0" Background="{StaticResource PanelBackground}" CornerRadius="12" Padding="12" BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                    <DataGrid x:Name="FilesGrid" ItemsSource="{Binding TopFiles}" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="FILE PATH" Binding="{Binding Path}" Width="3*"/>
                            <DataGridTextColumn Header="SIZE" Binding="{Binding SizeHuman}" Width="*"/>
                            <DataGridTextColumn Header="% OF DRIVE" Binding="{Binding PercentText}" Width="*"/>
                            <DataGridTextColumn Header="MODIFIED" Binding="{Binding ModifiedText}" Width="1.5*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>